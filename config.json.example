{
  "pollIntervalMs": 30000,
  "pipePath": "/tmp/dispatch.pipe",
  "maxLoopIterations": 3,
  "defaultTimeouts": {
    "triage": 60,
    "work": 1800,
    "parse": 60,
    "answer": 60
  },
  "notifications": {
    "escalation": "telegram",
    "channel": ""
  },
  "openclaw": {
    "binary": "openclaw",
    "gatewayUrl": "",
    "gatewayToken": "",
    "spawnMethod": "cli",
    "sessionTimeout": 0,
    "agents": {
      "kit": {
        "id": "kit",
        "workspaceDir": "/home/kit/.openclaw/workspace"
      },
      "hawk": {
        "id": "hawk",
        "workspaceDir": "/home/hawk/.openclaw/workspace"
      }
    }
  }
}
