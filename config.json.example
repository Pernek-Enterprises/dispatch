{
  "pollIntervalMs": 30000,
  "pipePath": "/tmp/dispatch.pipe",
  "maxLoopIterations": 3,
  "defaultTimeouts": {
    "triage": 60,
    "work": 1800,
    "parse": 60,
    "answer": 60
  },
  "notifications": {
    "escalation": "discord",
    "target": "#dispatch"
  },
  "pi": {
    "binary": "pi",
    "defaultTools": ["read", "bash", "edit", "write"]
  }
}
