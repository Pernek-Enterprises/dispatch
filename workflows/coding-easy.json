{
  "name": "coding-easy",
  "description": "Simple coding tasks \u2014 bug fixes, small features, straightforward changes.",
  "note": "Model values must match your ~/.pi/agent/models.json (provider/model-id format). Update these for your installation.",
  "firstStep": "spec",
  "steps": {
    "spec": {
      "role": "coder",
      "model": "CHANGE-ME/your-large-model",
      "timeout": 600,
      "next": "code",
      "artifactsIn": [],
      "artifactsOut": [
        "spec.md"
      ]
    },
    "code": {
      "role": "coder",
      "model": "CHANGE-ME/your-small-model",
      "timeout": 1800,
      "next": "review",
      "artifactsIn": [
        "spec.md"
      ],
      "artifactsOut": [
        "diff.patch"
      ]
    },
    "review": {
      "role": "reviewer",
      "model": "CHANGE-ME/your-small-model",
      "timeout": 900,
      "branch": {
        "ACCEPTED": "ready",
        "DENIED": "fix"
      },
      "maxIterations": 3,
      "artifactsIn": [
        "spec.md",
        "diff.patch"
      ],
      "artifactsOut": [
        "review.md"
      ]
    },
    "fix": {
      "role": "coder",
      "model": "CHANGE-ME/your-large-model",
      "timeout": 1200,
      "next": "review",
      "artifactsIn": [
        "review.md",
        "spec.md"
      ],
      "artifactsOut": [
        "diff.patch"
      ]
    },
    "ready": {
      "type": "human",
      "timeout": 0
    }
  },
  "destroy": {
    "timeout": 300,
    "actions": [
      "archive_artifacts",
      "cleanup_jobs"
    ]
  }
}